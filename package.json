{
  "name": "warrantyvault-pk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/check-env.mjs && next dev",
    "dev:fresh": "powershell -ExecutionPolicy Bypass -File scripts/kill-dev-ports.ps1 && node scripts/check-env.mjs && npm run clean && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev:clean": "npm run clean && npm run dev",
    "cap:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "powershell -ExecutionPolicy Bypass -File scripts/build-apk.ps1",
    "vapid:generate": "node scripts/generate-vapid.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "node scripts/check-env.mjs && prisma migrate deploy && tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "deploy:registry": "node scripts/deploy-registry.mjs",
    "setup:polygon": "node scripts/setup-polygon.mjs",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "framer-motion": "^12.41.0",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "pdf-lib": "^1.17.1",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.5.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "solc": "^0.8.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
