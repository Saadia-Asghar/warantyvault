# ─── Required (local + Vercel) ─────────────────────────────────────
# PostgreSQL — Neon, Supabase, or Vercel Postgres (NOT sqlite on Vercel)

# Pooled / serverless URL (app queries)
# Supabase: "Transaction" pooler, port 6543, add ?pgbouncer=true
# Neon: use the pooled connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/warrantyvault?sslmode=require"

# Direct URL (Prisma migrations — required with Supabase pooler)
# Supabase: "Session" mode, port 5432 (no pgbouncer param)
# Neon: use the direct / unpooled connection string (can match DATABASE_URL)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/warrantyvault?sslmode=require"

# Min 32 chars — generate: openssl rand -base64 32
AUTH_SECRET="generate-a-random-secret-at-least-32-characters-long"

# Production: https://your-app.vercel.app (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Email (recommended for production) ────────────────────────────
# https://resend.com — verify your domain for EMAIL_FROM
RESEND_API_KEY=""
EMAIL_FROM="WarrantyVault PK <noreply@yourdomain.com>"
ADMIN_EMAIL="support@yourdomain.com"

# ─── Optional: SMS (not implemented yet) ───────────────────────────
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# ─── Optional: Real blockchain (simulated in DB by default) ────────
# POLYGON_RPC_URL="https://rpc-amoy.polygon.technology"
# POLYGON_PRIVATE_KEY=""
# WARRANTY_REGISTRY_CONTRACT=""
