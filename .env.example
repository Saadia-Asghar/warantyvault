# ─── Required (local + Vercel) ─────────────────────────────────────
# PostgreSQL — Neon, Supabase, or Vercel Postgres (NOT sqlite on Vercel)

# Supabase project gdmciybkdiuomowvpjyn (ap-southeast-2 Sydney)
# Run: .\scripts\setup-supabase.ps1 -Password "your-db-password"

# Transaction pooler — app queries (port 6543)
DATABASE_URL="postgresql://postgres.gdmciybkdiuomowvpjyn:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session pooler — migrations (port 5432)
DIRECT_URL="postgresql://postgres.gdmciybkdiuomowvpjyn:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Min 32 chars — generate: openssl rand -base64 32
AUTH_SECRET="generate-a-random-secret-at-least-32-characters-long"

# Production: https://your-app.vercel.app (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo credentials on landing/auth — false on production (default: dev only)
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS="false"

# Web push (optional) — run: node scripts/generate-vapid.mjs
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@warrantyvault.pk"

# ─── Email (recommended for production) ────────────────────────────
# https://resend.com — verify your domain for EMAIL_FROM
RESEND_API_KEY=""
EMAIL_FROM="WarrantyVault PK <noreply@yourdomain.com>"
ADMIN_EMAIL="support@yourdomain.com"

# ─── Optional: SMS (Twilio) ───────────────────────────────────────
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# ─── Cron (Vercel daily expiry reminders) ──────────────────────────
# Generate: openssl rand -base64 32
CRON_SECRET="generate-a-random-cron-secret"

# ─── Optional: Real blockchain (Polygon Amoy testnet) ───────────────
# Without these, warranties use a local audit registry (still tamper-evident in DB).
# 1. Get Amoy MATIC: https://faucet.polygon.technology/
# 2. Run: npm run deploy:registry
# 3. Paste contract address below
POLYGON_RPC_URL="https://rpc-amoy.polygon.technology"
POLYGON_PRIVATE_KEY=""
WARRANTY_REGISTRY_CONTRACT=""
NEXT_PUBLIC_WARRANTY_REGISTRY_CONTRACT=""
NEXT_PUBLIC_CHAIN_ID="80002"
NEXT_PUBLIC_POLYGON_EXPLORER="https://amoy.polygonscan.com"

# ─── Optional: Real blockchain (legacy — simulated in DB if unset above) ─
